{
  "name": "prosodio",
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "components/*",
      "apps/*"
    ],
    "catalogs": {
      "runtime": {
        "@likecoin/epub-ts": "^0.6.7",
        "jsdom": "^29.1.1",
        "valibot": "^1.2.0",
        "zod": "^4.3.6"
      }
    }
  },
  "scripts": {
    "test": "bun test",
    "test:e2e": "RUN_E2E_TESTS=1 bun test",
    "check": "tsc --noEmit && tsc --noEmit -p apps/bookplayer",
    "fmt": "bunx prettier --write .",
    "fmt:check": "bunx prettier --check .",
    "lint": "bun run lint:js && bun run lint:md",
    "lint:js": "bunx eslint .",
    "lint:md": "bunx markdownlint-cli2 \"**/*.md\" \"*.md\"",
    "ci": "bun run fmt:check && bun run lint && bun run check && bun run test",
    "outdated": "bun outdated -r",
    "outdated:fix": "bun update -i -r",
    "sanity": "echo \"Validate environment ... coming to a script (very) near you\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.9.1",
    "typescript-eslint": "^8.62.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "prettier": {
    "proseWrap": "always"
  }
}
