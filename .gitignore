# volatile local outputs / scratch
data

# test fixtures (recreate via scripts/fetch-and-check-fixtures.ts): ignore only
# the large fetched audiobook .m4b (~98MB). The small produced audio m4b, the
# epub, jfk.mp3, and the manifest are all committed — as are the purpose-built
# Fixture Rabbits m4bs (5-10MB, no upstream to refetch from).
fixtures/audiobooks/**/*.m4b
!fixtures/audiobooks/Beatrix Potter - Fixture Rabbits/**/*.m4b

# dependencies (bun install)
node_modules

# dotenv environment variable files
.env
.env.local
# .env.development.local
# .env.test.local
# .env.production.local

# Finder (MacOS) folder config
.DS_Store

# Claude Code personal settings only (per-user permission allowlist). The rest
# of .claude/ (launch configs, and any future shared commands/agents/hooks/
# settings.json) IS tracked — never ignore the whole directory.
.claude/settings.local.json
