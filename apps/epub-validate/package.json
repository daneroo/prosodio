{
  "name": "@prosodio/epub-validate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:browser": "bun build src/browser/entry.ts --target=browser --format=iife --outfile=dist/epubts-browser.js",
    "validate": "bun run build:browser && bun run src/index.ts",
    "postinstall": "playwright install chromium"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3"
  },
  "dependencies": {
    "@likecoin/epub-ts": "catalog:runtime",
    "@storyteller-platform/epub": "^0.6.2",
    "jsdom": "catalog:runtime",
    "linkedom": "^0.18.12",
    "playwright": "^1.61.0",
    "zod": "catalog:runtime"
  }
}
